# --- required ---
ANTHROPIC_API_KEY=sk-ant-...
# Shown only once when you create the agent key in Wallbit (read + trade scopes)
WALLBIT_API_KEY=

# --- execution mode ---
# dry_run: fills simulados (paper), para los primeros 3-5 dias.
# notify:  fase live de v1. El sistema manda la orden exacta por webhook y la
#          ejecutas a mano en la app de Wallbit; el fill real se detecta por
#          API (solo requiere scope read, funciona con el plan gratis).
# live:    ejecucion directa via API (requiere Wallbit Pro). Mismo codigo.
EXECUTION_MODE=dry_run

# --- models (change tier without touching code) ---
PLANNER_MODEL=claude-sonnet-4-6
REVIEW_MODEL=claude-fable-5
REVIEW_FALLBACK_MODEL=claude-sonnet-4-6
ESCALATION_MODEL=claude-haiku-4-5

# --- knobs ---
TICK_INTERVAL_SEC=90
PLANNER_MAX_WEB_SEARCHES=6
MIDDAY_ENABLED=true
INITIAL_CAPITAL_USD=150
PRICE_SOURCE=yahoo
COST_ALERT_DAILY_USD=1.5

# --- notifications (Discord/Slack webhook or any JSON endpoint) ---
WEBHOOK_URL=

# --- dashboard sync (optional; agent works fine without it) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SYNC_INTERVAL_MIN=15
